# =============================================================================
# Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local for local development

# API Base URL
VITE_API_URL=https://app-qgp-prod.azurewebsites.net

# Production SPA base (Entra redirect / email links): use SWA hostname from
# docs/evidence/environment_endpoints.json (default Azure hostname, not an unbound custom domain).
# Example: VITE_AZURE_REDIRECT_URI=https://purple-water-03205fa03.6.azurestaticapps.net/login

# =============================================================================
# Azure AD / Microsoft Entra ID Configuration (Required for SSO)
# =============================================================================
# These enable "Sign in with Microsoft" functionality

# Azure AD Application (client) ID
VITE_AZURE_CLIENT_ID=__YOUR_AZURE_APP_CLIENT_ID__

# Azure AD Authority URL (includes tenant ID)
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/__YOUR_TENANT_ID__

# Redirect URI after Azure AD authentication (must match App Registration)
VITE_AZURE_REDIRECT_URI=http://localhost:3000/login

# =============================================================================
# Error Tracking (Optional)
# =============================================================================
# Endpoint for lightweight client-side error reporting via navigator.sendBeacon.
# Leave blank to disable remote reporting (errors still log to console in dev).
VITE_ERROR_ENDPOINT=

# =============================================================================
# Development Configuration
# =============================================================================
# For local development, update these values:
# VITE_API_URL=http://localhost:8000
# VITE_AZURE_REDIRECT_URI=http://localhost:3000/login

# =============================================================================
# Azure AD App Registration Requirements
# =============================================================================
# Your Azure AD app registration must have:
# 1. Platform: Single-page application (SPA)
# 2. Redirect URIs configured for both:
#    - Admin login: /login
#    - Portal login: /portal
# 3. ID tokens enabled (under Authentication > Implicit grant)
# 4. API permissions: openid, profile, email (Microsoft Graph)

{
  "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "API Health Dashboard — Quality Governance Platform",
    "version": "1.0.0",
    "created": "2026-03-07"
  },
  "resources": [
    {
      "type": "Microsoft.Portal/dashboards",
      "apiVersion": "2020-09-01-preview",
      "name": "govplat-api-health",
      "location": "[resourceGroup().location]",
      "properties": {
        "lenses": {
          "0": {
            "order": 0,
            "parts": {
              "0": {
                "position": { "x": 0, "y": 0, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {
                    "title": "Request Rate (req/min)",
                    "query": "requests | summarize RequestCount=count() by bin(timestamp, 1m) | order by timestamp desc | take 60",
                    "visualization": "linechart"
                  }
                }
              },
              "1": {
                "position": { "x": 6, "y": 0, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {
                    "title": "Latency Percentiles (p50 / p95 / p99)",
                    "query": "requests | summarize p50=percentile(duration, 50), p95=percentile(duration, 95), p99=percentile(duration, 99) by bin(timestamp, 5m) | order by timestamp desc | take 60",
                    "visualization": "linechart"
                  }
                }
              },
              "2": {
                "position": { "x": 0, "y": 4, "colSpan": 4, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {
                    "title": "Error Rate (4xx + 5xx)",
                    "query": "requests | where resultCode >= 400 | summarize ErrorCount=count() by bin(timestamp, 5m), ErrorBucket=iff(resultCode >= 500, '5xx', '4xx') | order by timestamp desc",
                    "visualization": "barchart"
                  }
                }
              },
              "3": {
                "position": { "x": 4, "y": 4, "colSpan": 4, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {
                    "title": "5xx Count by Endpoint",
                    "query": "requests | where resultCode >= 500 | summarize Count=count() by name | order by Count desc | take 20",
                    "visualization": "table"
                  }
                }
              },
              "4": {
                "position": { "x": 8, "y": 4, "colSpan": 4, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {
                    "title": "Availability (success rate %)",
                    "query": "requests | summarize SuccessRate=round(100.0 * countif(resultCode < 500) / count(), 2) by bin(timestamp, 5m) | order by timestamp desc | take 60",
                    "visualization": "linechart"
                  }
                }
              },
              "5": {
                "position": { "x": 0, "y": 8, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {
                    "title": "Slowest Endpoints (p99 > 2s)",
                    "query": "requests | summarize p99=percentile(duration, 99), Count=count() by name | where p99 > 2000 | order by p99 desc | take 15",
                    "visualization": "table"
                  }
                }
              },
              "6": {
                "position": { "x": 6, "y": 8, "colSpan": 6, "rowSpan": 4 },
                "metadata": {
                  "type": "Extension/Microsoft_OperationsManagementSuite_Workspace/PartType/LogsDashboardPart",
                  "settings": {
                    "title": "Database Health (readyz)",
                    "query": "requests | where name contains 'readyz' | extend dbStatus=tostring(customDimensions.database) | summarize count() by bin(timestamp, 5m), dbStatus",
                    "visualization": "linechart"
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
